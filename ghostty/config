# By default Reload config with ctrl + shift + :withi, 
theme = Flexoki Dark 
background = #000000
background-opacity = 0.75
background-blur-radius = 23

font-family = JetBrainsMonoNL Nerd Font 
font-size = 12 
cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true

mouse-hide-while-typing = true

confirm-close-surface = false
window-decoration = auto
window-padding-x = 10
window-padding-y = 10
window-padding-balance = false

auto-update = check
auto-update-channel = stable

# extras
shell-integration-features = no-cursor,ssh-terminfo,ssh-env
copy-on-select = true
app-notifications = no-clipboard-copy

#startup
quit-after-last-window-closed = false
# quit-after-last-window-closed = true
# quit-after-last-window-closed-delay = 5m

# trying out ghostty tab features
keybind = ctrl+n=new_window

keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

keybind = ctrl+a>h=new_split:left
keybind = ctrl+a>j=new_split:down
keybind = ctrl+a>k=new_split:up
keybind = ctrl+a>l=new_split:right
keybind = ctrl+a>f=toggle_split_zoom

keybind = ctrl+a>n=next_tab
keybind = ctrl+a>p=previous_tab

